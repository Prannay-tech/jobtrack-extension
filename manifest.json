{
  "manifest_version": 3,
  "name": "JobTrack",
  "version": "3.0.0",
  "description": "Log job applications with one shortcut. Tracks to Google Sheets + Calendar automatically.",

  "permissions": ["storage", "identity", "activeTab", "notifications", "scripting", "alarms"],
  "host_permissions": [
    "https://sheets.googleapis.com/*",
    "https://calendar.googleapis.com/*",
    "https://*.workers.dev/*"
  ],

  "oauth2": {
    "client_id": "1061501081696-m3fvokg7dl1isn0feivqbsctsk0b3p6q.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets",
      "https://www.googleapis.com/auth/calendar.events"
    ]
  },

  "commands": {
    "log-application": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Log current job application"
    }
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "JobTrack",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
