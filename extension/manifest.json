{
  "manifest_version": 3,
  "name": "JobTrack",
  "version": "4.0.0",
  "description": "Log job applications with one shortcut. AI-powered extraction, live dashboard, and status tracking.",

  "permissions": ["storage", "activeTab", "notifications", "scripting", "alarms"],
  "host_permissions": [
    "https://*.workers.dev/*"
  ],

  "commands": {
    "log-application": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Log current job application"
    }
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "JobTrack",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "https://jobtrack-web-prannay-khushalanis-projects.vercel.app/auth*",
        "https://jobtrack-web-six.vercel.app/auth*",
        "https://jobtrack-web-git-main-prannay-khushalanis-projects.vercel.app/auth*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
